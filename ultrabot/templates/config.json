{
  "providers": {
    "openrouter": {
      "apiKey": ""
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "provider": "auto",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "timezone": "UTC"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "sendMaxRetries": 3
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18800,
    "heartbeat": {
      "enabled": true,
      "intervalS": 1800,
      "keepRecentMessages": 8
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "duckduckgo",
        "maxResults": 5
      }
    },
    "exec": {
      "enable": true,
      "timeout": 60
    },
    "restrictToWorkspace": false,
    "mcpServers": {}
  },
  "security": {
    "rateLimitRpm": 60,
    "rateLimitBurst": 10,
    "maxInputLength": 100000,
    "blockedPatterns": []
  }
}
